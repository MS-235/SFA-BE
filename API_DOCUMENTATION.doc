<h4>Query 3: Insert Area</h4>
<pre>INSERT INTO "Tbl_Area_Mst" ("C_Code", "C_Name", "C_Sh_Name", "C_Region_Code", "C_SalesHQ", "c_district_code", "C_Classification_Code", "n_lami", "n_lgmi", "n_deleted", "d_created", "c_modifier")
