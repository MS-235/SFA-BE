{
  "info": {
    "name": "SFA Designation Master API",
    "_postman_id": "sfa-designation-master-collection",
    "description": "CRUD API for Designation Master.\n\nTable: tbl_desig_mst\n\nPre-requisite:\n1. Login using the Auth collection first\n2. The Login request auto-saves accessToken to collection variables\n3. All requests here use {{accessToken}} automatically\n\nCode is auto-generated with prefix DES (DES001, DES002...)\nSearch behavior:\n- Default (no search / empty) -> returns empty data.\n- search=* -> returns all active records.\n- search=keyword -> case-insensitive search matching name and code (e.g. searching '0001' matches 'DES0001').",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Paste your accessToken here, or run Login from Auth collection first"
    },
    {
      "key": "desigCode",
      "value": "DES001",
      "type": "string",
      "description": "Code of the designation to update/delete"
    }
  ],
  "item": [
    {
      "name": "0. Get Next Code",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation/next-code",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation", "next-code"]
        },
        "description": "Returns the next auto-generated designation code (e.g. DES003).\n\nUses the SERIAL sequence on the table — always increments forward, never reuses a code even after hard delete."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"nextCode\": \"DES003\"\n}"
        }
      ]
    },
    {
      "name": "1. Create Designation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success && res.data) {",
              "  pm.collectionVariables.set('desigCode', res.data.c_code);",
              "  console.log('✅ Created:', res.data.c_code);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"c_name\": \"Sales Manager\",\n  \"c_sh_name\": \"SM\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation"]
        },
        "description": "Creates a new designation.\n\nCode is auto-generated incrementally with prefix DES (DES001, DES002...).\nThe created code is auto-saved to {{desigCode}} variable.\n\nFields:\n- c_name (required): Designation name\n- c_sh_name (optional): Short name"
      },
      "response": [
        {
          "name": "Success - 201",
          "status": "Created",
          "code": 201,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Designation created successfully.\",\n  \"data\": {\n    \"c_code\": \"DES001\",\n    \"c_name\": \"Sales Manager\",\n    \"c_sh_name\": \"SM\"\n  }\n}"
        },
        {
          "name": "Error - Duplicate Name",
          "status": "Conflict",
          "code": 409,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Designation \\\"Sales Manager\\\" already exists.\"\n}"
        },
        {
          "name": "Error - Missing Name",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Name (c_name) is required.\"\n}"
        }
      ]
    },
    {
      "name": "2. Get All (Default - Empty Search)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation"]
        },
        "description": "By default (empty search term), returns empty data block without querying database."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 0,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 0\n  },\n  \"data\": []\n}"
        }
      ]
    },
    {
      "name": "3. Get All (search=*)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation?search=*&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation"],
          "query": [
            { "key": "search", "value": "*" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Returns all active designations paginated."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 2,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"c_code\": \"DES001\", \"c_name\": \"Sales Manager\", \"c_sh_name\": \"SM\", \"d_created\": \"2026-05-25T05:00:00.000Z\", \"d_modified\": null },\n    { \"c_code\": \"DES002\", \"c_name\": \"Regional Manager\", \"c_sh_name\": \"RM\", \"d_created\": \"2026-05-25T05:01:00.000Z\", \"d_modified\": null }\n  ]\n}"
        }
      ]
    },
    {
      "name": "4. Search — Keyword (Sales)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation?search=Sales&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation"],
          "query": [
            { "key": "search", "value": "Sales" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Search designations whose name or code contains 'Sales'."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 1,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"c_code\": \"DES001\", \"c_name\": \"Sales Manager\", \"c_sh_name\": \"SM\" }\n  ]\n}"
        }
      ]
    },
    {
      "name": "5. Search — Code digits (0001)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation?code=0001&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation"],
          "query": [
            { "key": "code", "value": "0001" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Search designations whose code contains '0001' (matches DES0001)."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 1,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"c_code\": \"DES0001\", \"c_name\": \"Sales Director\", \"c_sh_name\": \"SD\" }\n  ]\n}"
        }
      ]
    },
    {
      "name": "6. Update Designation",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"c_name\": \"Senior Sales Manager\",\n  \"c_sh_name\": \"SSM\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation/{{desigCode}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation", "{{desigCode}}"]
        },
        "description": "Update name and/or short name of a designation.\n\nCode cannot be changed."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Designation updated successfully.\",\n  \"data\": {\n    \"c_code\": \"DES001\",\n    \"c_name\": \"Senior Sales Manager\",\n    \"c_sh_name\": \"SSM\"\n  }\n}"
        },
        {
          "name": "Error - Duplicate Name",
          "status": "Conflict",
          "code": 409,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Another designation with name \\\"Senior Sales Manager\\\" already exists.\"\n}"
        }
      ]
    },
    {
      "name": "7. Delete Designation",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/designation/{{desigCode}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "designation", "{{desigCode}}"]
        },
        "description": "Permanently deletes a designation from the database.\n\nThe record is physically removed and cannot be recovered."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Designation \\\"DES001\\\" deleted successfully.\"\n}"
        },
        {
          "name": "Error - Not Found",
          "status": "Not Found",
          "code": 404,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Designation \\\"DES001\\\" not found.\"\n}"
        }
      ]
    }
  ]
}
