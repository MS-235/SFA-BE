{
  "info": {
    "name": "SFA Department Master API",
    "_postman_id": "sfa-department-master-collection",
    "description": "CRUD API for Department Master.\n\nTable: tbl_department_mst\n\nCode auto-generated with prefix DP (DP0001, DP0002...)\n\nTravel desk location & Material desk location are fixed values from backend:\n  - HYDERABAD\n  - MUMBAI\n(Call GET /locations to get the current list)\n\nSearch behavior:\n- Default (no search / empty) -> returns empty data.\n- search=* -> returns all active records.\n- search=keyword -> case-insensitive search matching name and code (e.g. searching '0001' matches 'DP0001').",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "deptCode",    "value": "DP0001", "type": "string" }
  ],
  "item": [
    {
      "name": "0. Get Next Code",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/department/next-code",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "department", "next-code"]
        },
        "description": "Returns the next auto-generated department code (e.g. DP0003).\n\nUses the SERIAL sequence on the table — always increments forward, never reuses a code even after hard delete."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"nextCode\": \"DP0003\"\n}"
        }
      ]
    },
    {
      "name": "0. Get Valid Locations (config)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/masters/department/locations",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department","locations"]
        },
        "description": "Returns the fixed list of valid travel/material desk locations.\nUse these values in the location fields when creating/updating a department.\nThis list is managed from the backend — scalable without DB changes."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"data\": [\n    { \"value\": \"HYDERABAD\", \"label\": \"Hyderabad\" },\n    { \"value\": \"MUMBAI\",    \"label\": \"Mumbai\"    }\n  ]\n}"
        }
      ]
    },
    {
      "name": "1. Create Department (minimal)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success && res.data) {",
              "  pm.collectionVariables.set('deptCode', res.data.c_code);",
              "  console.log('✅ Created:', res.data.c_code);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"c_name\": \"Sales\",\n  \"c_short_name\": \"SLS\",\n  \"n_sfa_role\": 1\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/masters/department",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department"]
        },
        "description": "Minimal create — only required fields.\nCode auto-generates as DP0001, DP0002...\n\nRequired:\n  c_name\n\nOptional:\n  c_short_name\n  c_travel_desk_location  — must be HYDERABAD or MUMBAI\n  c_travel_desk_incharge  — employee code from FS master\n  c_material_desk_location\n  c_material_desk_incharge\n  n_sfa_role              — 0 (No) or 1 (Yes), default 0"
      },
      "response": [
        {
          "name": "Success - 201",
          "status": "Created",
          "code": 201,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Department created successfully.\",\n  \"data\": {\n    \"c_code\": \"DP0001\",\n    \"c_name\": \"Sales\",\n    \"c_short_name\": \"SLS\",\n    \"c_travel_desk_location\": null,\n    \"c_travel_desk_incharge\": null,\n    \"c_material_desk_location\": null,\n    \"c_material_desk_incharge\": null,\n    \"n_sfa_role\": 1,\n    \"sfa_role_label\": \"Yes\"\n  }\n}"
        }
      ]
    },
    {
      "name": "2. Create Department (full)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success && res.data) {",
              "  pm.collectionVariables.set('deptCode', res.data.c_code);",
              "  console.log('✅ Created:', res.data.c_code);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"c_name\": \"Marketing\",\n  \"c_short_name\": \"MKT\",\n  \"c_travel_desk_location\": \"HYDERABAD\",\n  \"c_travel_desk_incharge\": null,\n  \"c_material_desk_location\": \"MUMBAI\",\n  \"c_material_desk_incharge\": null,\n  \"n_sfa_role\": 0\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/masters/department",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department"]
        },
        "description": "Full create with all fields.\nLocation values must be exactly: HYDERABAD or MUMBAI (case-insensitive).\nIncharge fields accept employee codes from Tbl_FS_Mst."
      },
      "response": [
        {
          "name": "Success - 201",
          "status": "Created",
          "code": 201,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Department created successfully.\",\n  \"data\": {\n    \"c_code\": \"DP0002\",\n    \"c_name\": \"Marketing\",\n    \"c_short_name\": \"MKT\",\n    \"c_travel_desk_location\": \"HYDERABAD\",\n    \"c_travel_desk_incharge\": null,\n    \"c_material_desk_location\": \"MUMBAI\",\n    \"c_material_desk_incharge\": null,\n    \"n_sfa_role\": 0,\n    \"sfa_role_label\": \"No\"\n  }\n}"
        },
        {
          "name": "Error - Invalid Location",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"errors\": [\n    \"Travel desk location must be one of: HYDERABAD, MUMBAI.\"\n  ]\n}"
        },
        {
          "name": "Error - Duplicate Name",
          "status": "Conflict",
          "code": 409,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Department \\\"Marketing\\\" already exists.\"\n}"
        }
      ]
    },
    {
      "name": "3. Get All (Default - Empty Search)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/masters/department",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department"]
        },
        "description": "By default (empty search term), returns empty data block without querying database."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 0,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 0\n  },\n  \"data\": []\n}"
        }
      ]
    },
    {
      "name": "4. Get All (search=*)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/masters/department?search=*&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department"],
          "query": [
            { "key": "search", "value": "*" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Returns all active departments paginated."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 2,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    {\n      \"C_Code\": \"DP0001\",\n      \"c_name\": \"Sales\",\n      \"c_short_name\": \"SLS\",\n      \"C_travel_desk_location\": null,\n      \"C_travel_desk_incharge\": null,\n      \"C_material_desk_location\": null,\n      \"C_material_desk_incharge\": null,\n      \"N_SFA_ROLE\": 1,\n      \"sfa_role_label\": \"Yes\"\n    },\n    {\n      \"C_Code\": \"DP0002\",\n      \"c_name\": \"Marketing\",\n      \"c_short_name\": \"MKT\",\n      \"C_travel_desk_location\": \"HYDERABAD\",\n      \"C_travel_desk_incharge\": null,\n      \"C_material_desk_location\": \"MUMBAI\",\n      \"C_material_desk_incharge\": null,\n      \"N_SFA_ROLE\": 0,\n      \"sfa_role_label\": \"No\"\n    }\n  ]\n}"
        }
      ]
    },
    {
      "name": "5. Search — Keyword (Sales)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/masters/department?search=Sales&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department"],
          "query": [
            { "key": "search", "value": "Sales" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Search departments whose name or code contains 'Sales'."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 1,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"C_Code\": \"DP0001\", \"c_name\": \"Sales\", \"c_short_name\": \"SLS\", \"N_SFA_ROLE\": 1, \"sfa_role_label\": \"Yes\" }\n  ]\n}"
        }
      ]
    },
    {
      "name": "6. Search — Code digits (0001)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/masters/department?code=0001&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department"],
          "query": [
            { "key": "code", "value": "0001" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Search departments whose code contains '0001' (matches DP0001)."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 1,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"C_Code\": \"DP0001\", \"c_name\": \"Sales\", \"c_short_name\": \"SLS\", \"N_SFA_ROLE\": 1, \"sfa_role_label\": \"Yes\" }\n  ]\n}"
        }
      ]
    },
    {
      "name": "7. Update Department",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"c_name\": \"Sales & Marketing\",\n  \"c_short_name\": \"S&M\",\n  \"c_travel_desk_location\": \"MUMBAI\",\n  \"c_travel_desk_incharge\": null,\n  \"c_material_desk_location\": \"HYDERABAD\",\n  \"c_material_desk_incharge\": null,\n  \"n_sfa_role\": 1\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/masters/department/{{deptCode}}",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department","{{deptCode}}"]
        },
        "description": "Update all fields of a department.\nCode cannot be changed.\nSame validations as Create apply."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Department updated successfully.\",\n  \"data\": {\n    \"c_code\": \"DP0001\",\n    \"c_name\": \"Sales & Marketing\",\n    \"c_short_name\": \"S&M\",\n    \"c_travel_desk_location\": \"MUMBAI\",\n    \"c_travel_desk_incharge\": null,\n    \"c_material_desk_location\": \"HYDERABAD\",\n    \"c_material_desk_incharge\": null,\n    \"n_sfa_role\": 1,\n    \"sfa_role_label\": \"Yes\"\n  }\n}"
        }
      ]
    },
    {
      "name": "8. Delete Department",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/masters/department/{{deptCode}}",
          "host": ["{{baseUrl}}"],
          "path": ["api","masters","department","{{deptCode}}"]
        },
        "description": "Permanently deletes a department from the database.\n\nThe record is physically removed and cannot be recovered."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Department \\\"DP0001\\\" deleted successfully.\"\n}"
        },
        {
          "name": "Error - Not Found",
          "status": "Not Found",
          "code": 404,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Department \\\"DP0001\\\" not found.\"\n}"
        }
      ]
    }
  ]
}
