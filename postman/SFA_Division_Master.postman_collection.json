{
  "info": {
    "name": "SFA Division Master API",
    "_postman_id": "sfa-division-master-collection",
    "description": "CRUD API for Division Master.\n\nTable: Tbl_Div_Mst\n\nPre-requisite:\n1. Login using the Auth collection first\n2. The Login request auto-saves accessToken to collection variables\n3. All requests here use {{accessToken}} automatically\n\nCode is auto-generated with prefix DI (DI0001, DI0034...)\nSearch behavior:\n- Default (no search / empty) -> returns empty data.\n- search=* -> returns all active records.\n- search=keyword -> case-insensitive search matching name and code (e.g. searching '0001' matches 'DI0001').",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Paste your accessToken here, or run Login from Auth collection first"
    },
    {
      "key": "divCode",
      "value": "DI0001",
      "type": "string",
      "description": "Code of the division to update/delete"
    }
  ],
  "item": [
    {
      "name": "1. Create Division",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.success && res.data) {",
              "  pm.collectionVariables.set('divCode', res.data.c_code);",
              "  console.log('✅ Created:', res.data.c_code);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"c_name\": \"Gastro Division\",\n  \"c_sh_name\": \"GD\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/masters/division",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "division"]
        },
        "description": "Creates a new division.\n\nCode is auto-generated incrementally with prefix DI (DI0001, DI0002...).\nThe created code is auto-saved to {{divCode}} variable.\n\nFields:\n- c_name (required): Division name\n- c_sh_name (optional): Short name"
      },
      "response": [
        {
          "name": "Success - 201",
          "status": "Created",
          "code": 201,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Division created successfully.\",\n  \"data\": {\n    \"c_code\": \"DI0001\",\n    \"c_name\": \"Gastro Division\",\n    \"c_sh_name\": \"GD\"\n  }\n}"
        },
        {
          "name": "Error - Duplicate Name",
          "status": "Conflict",
          "code": 409,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Division \\\"Gastro Division\\\" already exists.\"\n}"
        },
        {
          "name": "Error - Missing Name",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Name (c_name) is required.\"\n}"
        }
      ]
    },
    {
      "name": "2. Get All (Default - Empty Search)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/division",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "division"]
        },
        "description": "By default (empty search term), returns empty data block without querying database."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 0,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 0\n  },\n  \"data\": []\n}"
        }
      ]
    },
    {
      "name": "3. Get All (search=*)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/division?search=*&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "division"],
          "query": [
            { "key": "search", "value": "*" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Returns all active divisions paginated."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 2,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"c_code\": \"DI0001\", \"c_name\": \"Gastro Division\", \"c_sh_name\": \"GD\", \"d_created\": \"2026-05-25T05:00:00.000Z\", \"d_modified\": null },\n    { \"c_code\": \"DI0002\", \"c_name\": \"Cardio Division\", \"c_sh_name\": \"CD\", \"d_created\": \"2026-05-25T05:01:00.000Z\", \"d_modified\": null }\n  ]\n}"
        }
      ]
    },
    {
      "name": "4. Search — Keyword (Gastro)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/division?search=Gastro&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "division"],
          "query": [
            { "key": "search", "value": "Gastro" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Search divisions whose name or code contains 'Gastro'."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 1,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"c_code\": \"DI0001\", \"c_name\": \"Gastro Division\", \"c_sh_name\": \"GD\" }\n  ]\n}"
        }
      ]
    },
    {
      "name": "5. Search — Code digits (0001)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/division?search=0001&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "division"],
          "query": [
            { "key": "search", "value": "0001" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        },
        "description": "Search divisions whose code contains '0001' (matches DI0001)."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"pagination\": {\n    \"total\": 1,\n    \"page\": 1,\n    \"limit\": 10,\n    \"totalPages\": 1\n  },\n  \"data\": [\n    { \"c_code\": \"DI0001\", \"c_name\": \"Gastro Division\", \"c_sh_name\": \"GD\" }\n  ]\n}"
        }
      ]
    },
    {
      "name": "6. Update Division",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type",  "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"c_name\": \"Senior Gastro Division\",\n  \"c_sh_name\": \"SGD\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/masters/division/{{divCode}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "division", "{{divCode}}"]
        },
        "description": "Update name and/or short name of a division.\n\nCode cannot be changed."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Division updated successfully.\",\n  \"data\": {\n    \"c_code\": \"DI0001\",\n    \"c_name\": \"Senior Gastro Division\",\n    \"c_sh_name\": \"SGD\"\n  }\n}"
        },
        {
          "name": "Error - Duplicate Name",
          "status": "Conflict",
          "code": 409,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Another division with name \\\"Senior Gastro Division\\\" already exists.\"\n}"
        }
      ]
    },
    {
      "name": "7. Delete Division",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/masters/division/{{divCode}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "masters", "division", "{{divCode}}"]
        },
        "description": "Soft deletes a division (sets n_deleted = 1).\n\nThe record is NOT physically removed from the database."
      },
      "response": [
        {
          "name": "Success - 200",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Division \\\"DI0001\\\" deleted successfully.\"\n}"
        },
        {
          "name": "Error - Not Found",
          "status": "Not Found",
          "code": 404,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Division \\\"DI0001\\\" not found.\"\n}"
        }
      ]
    }
  ]
}
